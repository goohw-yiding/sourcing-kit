generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users        User[]
  suppliers    Supplier[]
  products     Product[]
  buyers       Buyer[]
  orders       Order[]
  subscription Subscription?
  payments     Payment[]
}

model Subscription {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  plan            String    @default("free")   // "free" | "taste" | "pro"
  billingType     String    @default("free")   // "free" | "once" | "monthly" | "yearly"
  status          String    @default("active") // "active" | "cancelled" | "past_due" | "expired"
  billingKey      String?   // 토스페이먼츠 빌링키 (monthly/yearly)
  customerKey     String?   // 토스페이먼츠 고객키
  expiresAt       DateTime? // taste 플랜 만료일
  nextBillingAt   DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  payments        Payment[]
}

model AiUsageLog {
  id        String   @id @default(cuid())
  tenantId  String
  date      String   // "YYYY-MM-DD" (KST 기준)
  count     Int      @default(0)

  @@unique([tenantId, date])
}

model Payment {
  id             String    @id @default(cuid())
  tenantId       String
  subscriptionId String?
  orderId        String    @unique
  paymentKey     String?
  amount         Int
  status         String    @default("pending") // "pending" | "done" | "cancelled" | "failed"
  method         String?
  receiptUrl     String?
  requestedAt    DateTime  @default(now())
  approvedAt     DateTime?

  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String   @unique
  password  String?
  role      String   @default("staff")
  createdAt DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[]
}

model Supplier {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  contact    String?
  phone      String?
  wechatId   String?
  marketArea String?
  address    String?
  category   String?
  url1688    String?
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  products   Product[]
}

model Product {
  id             String   @id @default(cuid())
  tenantId       String
  supplierId     String?
  createdById    String?

  nameCn         String?
  nameKr         String
  imageUrl       String?
  memo           String?

  costCny        Float
  exchangeRate   Float
  packagingCost  Float   @default(0)
  chinaShipping  Float   @default(0)
  agentFeeRate   Float   @default(0)
  cbm            Float   @default(0)
  cbmRate        Float   @default(90000)
  hasCoOrigin    Boolean @default(false)
  coOriginCost   Float   @default(0)
  customsRate    Float   @default(0.08)
  hsCode         String?
  hsDescription  String?
  moq            Int?
  inlandShipping Float   @default(0)

  costKrw        Float?
  agentFee       Float?
  cbmShipping    Float?
  customsDuty    Float?
  vat            Float?
  landedCost     Float?

  status         String  @default("sourcing")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  createdBy      User?     @relation(fields: [createdById], references: [id])
  proposalItems  ProposalItem[]
  orders         Order[]
}

model Buyer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  contact   String?
  phone     String?
  kakaoId   String?
  email     String?
  category  String?
  memo      String?
  createdAt DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  proposals Proposal[]
  orders    Order[]
}

model Proposal {
  id         String    @id @default(cuid())
  tenantId   String
  buyerId    String
  title      String
  shareToken String    @unique @default(cuid())
  viewedAt   DateTime?
  createdAt  DateTime  @default(now())

  buyer      Buyer          @relation(fields: [buyerId], references: [id])
  items      ProposalItem[]
}

model ProposalItem {
  id         String  @id @default(cuid())
  proposalId String
  productId  String
  priceKrw   Float
  quantity   Int     @default(1)
  memo       String?

  proposal   Proposal @relation(fields: [proposalId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model TempImage {
  id        String   @id @default(cuid())
  data      String   // base64 data URL
  mimeType  String   @default("image/jpeg")
  createdAt DateTime @default(now())
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model GiftCode {
  id          String    @id @default(cuid())
  code        String    @unique           // 예: GIFT-X7K2
  plan        String    @default("pro")   // "taste" | "pro"
  memo        String?                     // 관리자 메모 (누구에게 줬는지)
  maxUses     Int       @default(1)       // 최대 사용 횟수
  usedCount   Int       @default(0)       // 현재 사용 횟수
  expiresAt   DateTime?                   // 만료일 (null = 무기한)
  usedByTenants String[] @default([])    // 사용한 tenantId 목록
  createdAt   DateTime  @default(now())
  createdBy   String?                     // 관리자 이메일
}

model Order {
  id              String    @id @default(cuid())
  tenantId        String
  buyerId         String?
  productId       String?
  orderNo         String?
  status          String    @default("ordered")
  quantity        Int?
  unitPriceCny    Float?    // 실제 발주 단가 (CNY)
  totalCny        Float?    // 총 발주금액 (CNY)
  totalKrw        Float?    // 총 원화 환산
  memo            String?
  orderedAt       DateTime  @default(now())   // 발주일
  shippedAt       DateTime?                   // 중국내 선적일
  expectedArrival DateTime?                   // 입고예정일
  updatedAt       DateTime  @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  buyer     Buyer?   @relation(fields: [buyerId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])
}
